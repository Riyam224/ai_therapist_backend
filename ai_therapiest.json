        "/api/therapist/generate/": {
            "post": {
                "operationId": "therapist_generate_create",
                "description": "\nSend an emoji and your thoughts to Luna (AI Therapist).\nLuna will respond with an empathetic, supportive message.\n\nThe entry is automatically saved to your journal history.\n        ",
                "summary": "Generate AI response",
                "tags": [
                    "Therapist"
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "user_id": {
                                        "type": "string",
                                        "example": "user_123"
                                    },
                                    "emoji": {
                                        "type": "string",
                                        "example": "ðŸ˜”"
                                    },
                                    "thoughts": {
                                        "type": "string",
                                        "example": "I feel overwhelmed lately"
                                    },
                                    "history": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "properties": {
                                                "role": {
                                                    "type": "string",
                                                    "example": "user"
                                                },
                                                "content": {
                                                    "type": "string",
                                                    "example": "I feel sad"
                                                }
                                            }
                                        },
                                        "example": []
                                    }
                                },
                                "required": [
                                    "user_id",
                                    "emoji",
                                    "thoughts"
                                ]
                            },
                            "examples": {
                                "OverwhelmedExample": {
                                    "value": {
                                        "user_id": "user_123",
                                        "emoji": "ðŸ˜”",
                                        "thoughts": "I feel very overwhelmed with everything lately",
                                        "history": []
                                    },
                                    "summary": "Overwhelmed example"
                                },
                                "HappyExample": {
                                    "value": {
                                        "user_id": "user_123",
                                        "emoji": "ðŸ˜Š",
                                        "thoughts": "I feel happy and grateful today!",
                                        "history": []
                                    },
                                    "summary": "Happy example"
                                },
                                "AnxiousExample": {
                                    "value": {
                                        "user_id": "user_123",
                                        "emoji": "ðŸ˜°",
                                        "thoughts": "I am anxious about my future career",
                                        "history": []
                                    },
                                    "summary": "Anxious example"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/MoodEntry"
                                }
                            }
                        },
                        "description": ""
                    },
                    "400": {
                        "description": "Missing user_id, emoji or thoughts"
                    }
                }
            }
        },
        "/api/therapist/history/": {
            "get": {
                "operationId": "therapist_history_list",
                "description": "\nReturns all saved mood journal entries for the given user, ordered by most recent first.\n\nEach entry contains:\n- **user_id** â€” the user ID the entry belongs to\n- **emoji** â€” the mood emoji selected by the user\n- **thoughts** â€” what the user shared\n- **ai_response** â€” Luna's empathetic response\n- **created_at** â€” timestamp of the entry\n        ",
                "summary": "Get mood history",
                "parameters": [
                    {
                        "in": "query",
                        "name": "user_id",
                        "schema": {
                            "type": "string"
                        },
                        "description": "User ID to filter mood history entries.",
                        "required": true
                    }
                ],
                "tags": [
                    "Therapist"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "$ref": "#/components/schemas/MoodEntry"
                                    }
                                },
                                "examples": {
                                    "HistoryResponse": {
                                        "value": [
                                            [
                                                {
                                                    "id": 1,
                                                    "user_id": "user_123",
                                                    "emoji": "ðŸ˜”",
                                                    "thoughts": "I feel overwhelmed",
                                                    "ai_response": "It sounds like you are carrying a lot right now...",
                                                    "created_at": "2026-03-27T12:00:00Z"
                                                },
                                                {
                                                    "id": 2,
                                                    "user_id": "user_123",
                                                    "emoji": "ðŸ˜Š",
                                                    "thoughts": "Feeling grateful today",
                                                    "ai_response": "That is beautiful! Gratitude is a powerful...",
                                                    "created_at": "2026-03-26T09:30:00Z"
                                                }
                                            ]
                                        ],
                                        "summary": "History response"
                                    }
                                }
                            }
                        },
                        "description": ""
                    },
                    "400": {
                        "description": "Missing user_id"
                    }
                }
            }
        },
        "/api/therapist/weekly-letter/": {
            "get": {
                "operationId": "therapist_weekly_letter_retrieve",
                "description": "Generates a personal weekly letter from Luna based on recent entries.",
                "summary": "Get Luna's weekly letter",
                "parameters": [
                    {
                        "in": "query",
                        "name": "user_id",
                        "schema": {
                            "type": "string"
                        },
                        "description": "User ID to filter weekly letter entries.",
                        "required": true
                    }
                ],
                "tags": [
                    "Therapist"
                ],
                "security": [
                    {
                        "jwtAuth": []
                    },
                    {}
                ],
                "responses": {
                    "200": {
                        "description": "Weekly letter"
                    },
                    "400": {
                        "description": "Missing user_id"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "BlankEnum": {
                "enum": [
                    ""
                ]
            },
            "ChangePassword": {
                "type": "object",
                "properties": {
                    "old_password": {
                        "type": "string",
                        "writeOnly": true
                    },
                    "new_password": {
                        "type": "string",
                        "writeOnly": true
                    },
                    "new_password_confirm": {
                        "type": "string",
                        "writeOnly": true
                    }
                },
                "required": [
                    "new_password",
                    "new_password_confirm",
                    "old_password"
                ]
            },
            "ForgotPassword": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email"
                    }
                },
                "required": [
                    "email"
                ]
            },
            "GenderEnum": {
                "enum": [
                    "male",
                    "female",
                    "other",
                    "prefer_not_to_say"
                ],
                "type": "string",
                "description": "* `male` - Male\n* `female` - Female\n* `other` - Other\n* `prefer_not_to_say` - Prefer not to say"
            },
            "Login": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email"
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true
                    }
                },
                "required": [
                    "email",
                    "password"
                ]
            },
            "Logout": {
                "type": "object",
                "properties": {
                    "refresh": {
                        "type": "string"
                    }
                },
                "required": [
                    "refresh"
                ]
            },
            "MoodEntry": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "readOnly": true
                    },
                    "user_id": {
                        "type": "string",
                        "pattern": "^[A-Za-z0-9_-]{3,128}$",
                        "maxLength": 128,
                        "minLength": 3
                    },
                    "emoji": {
                        "type": "string",
                        "maxLength": 10
                    },
                    "thoughts": {
                        "type": "string"
                    },
                    "ai_response": {
                        "type": "string",
                        "readOnly": true
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "readOnly": true
                    }
                },
                "required": [
                    "ai_response",
                    "created_at",
                    "emoji",
                    "id",
                    "thoughts",
                    "user_id"
                ]
            },
            "PatchedUserProfileUpdate": {
                "type": "object",
                "properties": {
                    "full_name": {
                        "type": "string",
                        "maxLength": 150
                    },
                    "phone_number": {
                        "type": "string",
                        "maxLength": 32
                    },
                    "bio": {
                        "type": "string",
                        "maxLength": 500
                    },
                    "date_of_birth": {
                        "type": "string",
                        "format": "date",
                        "nullable": true
                    },
                    "gender": {
                        "oneOf": [
                            {
                                "$ref": "#/components/schemas/GenderEnum"
                            },
                            {
                                "$ref": "#/components/schemas/BlankEnum"
                            }
                        ]
                    }
                }
            },
            "ProfileImage": {
                "type": "object",
                "properties": {
                    "image": {
                        "type": "string",
                        "format": "uri"
                    }
                },
                "required": [
                    "image"
                ]
            },
            "Register": {
                "type": "object",
                "properties": {
                    "email": {
                        "type": "string",
                        "format": "email"
                    },
                    "username": {
                        "type": "string",
                        "nullable": true
                    },
                    "password": {
                        "type": "string",
                        "writeOnly": true
                    },
                    "password_confirm": {
                        "type": "string",
                        "writeOnly": true
                    }
                },
                "required": [
                    "email",
                    "password",
